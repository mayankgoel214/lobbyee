# Copy to .env.local and fill in. NEVER commit real values — .gitignore
# excludes .env* (this example file is the only exception).

# --- Database (Supabase → Project Settings → Database) ---
# Pooled connection for the app (Supavisor, port 6543, transaction mode).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for migrations (port 5432).
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Bypasses RLS — used for admin/service operations exclusively.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Conversation engine (aistudio.google.com/apikey — free tier) ---
GEMINI_API_KEY=""
