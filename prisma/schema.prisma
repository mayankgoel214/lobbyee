// Lobbyee — Phase 0 schema: multi-tenant foundation.
// Tenancy model: every tenant-scoped table carries workspace_id; Postgres RLS
// is the source of truth (policies live in the migration SQL alongside these
// tables). See docs/architecture.md §3–4.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  manager
  staff
}

enum MemberStatus {
  pending
  active
  removed
}

enum Plan {
  trial
  starter
}

model Workspace {
  id                String       @id @default(uuid()) @db.Uuid
  slug              String       @unique
  name              String
  industry          String?
  plan              Plan         @default(trial)
  sessionCapMonthly Int          @default(50) @map("session_cap_monthly")
  // Atomic usage counter (architecture §7b): incremented by the cap guard,
  // reset by the invoice.paid webhook. Deliberately NOT client-updatable —
  // migration 4 tightens the workspace UPDATE grant to (name, industry) so
  // billing columns are service-path only.
  sessionsUsedThisPeriod Int     @default(0) @map("sessions_used_this_period")
  stripeCustomerId  String?      @unique @map("stripe_customer_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  memberships       Membership[]
  personas          Persona[]
  scenarios         Scenario[]
  sessions          Session[]
  subscription      Subscription?

  @@map("workspace")
}

// ---------------------------------------------------------------------------
// Phase 4 — billing (docs/architecture.md §7b, §13 Phase 4)
// ---------------------------------------------------------------------------

// Mirror of the workspace's Stripe subscription — written ONLY by the
// webhook handler (service path). Workspace admins can read it (billing
// page); clients can never write it.
model Subscription {
  workspaceId          String    @id @map("workspace_id") @db.Uuid
  stripeSubscriptionId String    @unique @map("stripe_subscription_id")
  stripeStatus         String    @map("stripe_status")
  currentPeriodEnd     DateTime  @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

// Processed Stripe webhook event ids — the idempotency ledger. A replayed
// or duplicated delivery hits the primary key and is skipped. Service-path
// only (no grants at all).
model StripeEvent {
  id        String   @id // Stripe event id (evt_...)
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("stripe_event")
}

// Mirrors auth.users (Supabase). Created by a DB trigger on signup —
// see supabase/migrations/0001_profile_trigger.sql.
model Profile {
  id          String       @id @db.Uuid
  email       String       @unique
  fullName    String?      @map("full_name")
  createdAt   DateTime     @default(now()) @map("created_at")
  memberships Membership[]

  @@map("profile")
}

model Membership {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  role        Role
  status      MemberStatus @default(pending)
  invitedBy   String?      @map("invited_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile     Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("membership")
}

// ---------------------------------------------------------------------------
// Phase 1 — conversation engine (docs/architecture.md §4–5)
// ---------------------------------------------------------------------------

enum SessionStatus {
  in_progress
  completed
  abandoned
  errored
}

enum Modality {
  voice
  text
}

enum TurnRole {
  user
  guest
  system
  coach
}

enum PromptKind {
  guest_system
  mood_update
  evaluator
}

// The "who" — a reusable guest identity. Workspace-scoped (managers author
// them via the constrained form — never a raw prompt field).
model Persona {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  name         String
  guestType    String    @map("guest_type")
  backstory    String
  voiceId      String?   @map("voice_id")
  baselineMood Json      @map("baseline_mood")
  createdAt    DateTime  @default(now()) @map("created_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions     Session[]

  @@index([workspaceId])
  @@map("persona")
}

// The "what" — a situation + success criteria. Library scenarios have
// workspace_id NULL and are readable by every workspace.
model Scenario {
  id              String    @id @default(uuid()) @db.Uuid
  workspaceId     String?   @map("workspace_id") @db.Uuid
  title           String
  situation       String
  difficulty      Int
  successCriteria Json      @map("success_criteria")
  isLibrary       Boolean   @default(false) @map("is_library")
  createdAt       DateTime  @default(now()) @map("created_at")
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions        Session[]

  @@index([workspaceId])
  @@map("scenario")
}

model Session {
  id                String             @id @default(uuid()) @db.Uuid
  workspaceId       String             @map("workspace_id") @db.Uuid
  personaId         String             @map("persona_id") @db.Uuid
  scenarioId        String             @map("scenario_id") @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  promptVersionId   String             @map("prompt_version_id") @db.Uuid
  status            SessionStatus      @default(in_progress)
  modality          Modality           @default(text)
  currentMood       Json               @map("current_mood")
  startedAt         DateTime           @default(now()) @map("started_at")
  endedAt           DateTime?          @map("ended_at")
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  persona           Persona            @relation(fields: [personaId], references: [id])
  scenario          Scenario           @relation(fields: [scenarioId], references: [id])
  promptVersion     PromptVersion      @relation(fields: [promptVersionId], references: [id])
  messages          Message[]
  evaluation        Evaluation?
  pendingEvaluation PendingEvaluation?

  @@index([workspaceId, userId, startedAt])
  @@map("session")
}

// Transcript turns — immutable by design (no UPDATE/DELETE grants or policies).
model Message {
  id           BigInt   @id @default(autoincrement())
  sessionId    String   @map("session_id") @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid // denormalized for RLS
  turnIndex    Int      @map("turn_index")
  role         TurnRole
  text         String
  moodSnapshot Json?    @map("mood_snapshot")
  createdAt    DateTime @default(now()) @map("created_at")
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  citedBy      EvaluationEvidence[]

  @@unique([sessionId, turnIndex])
  @@index([workspaceId])
  @@map("message")
}

// Registry of prompt template versions (templates live in prompts/ as code;
// every session records which version produced it — reproducibility).
model PromptVersion {
  id          String       @id @default(uuid()) @db.Uuid
  kind        PromptKind
  version     String
  createdAt   DateTime     @default(now()) @map("created_at")
  sessions    Session[]
  evaluations Evaluation[]

  @@unique([kind, version])
  @@map("prompt_version")
}

// ---------------------------------------------------------------------------
// Phase 2 — evaluation engine (docs/architecture.md §6)
// ---------------------------------------------------------------------------

enum Competency {
  empathy
  clarity
  problem_solving
  professionalism
}

enum EvidenceKind {
  strength
  missed_opportunity
}

// One per completed session — written by the service path only (clients have
// SELECT, nothing else). sessionId is unique → re-runs are no-ops.
model Evaluation {
  id                       String               @id @default(uuid()) @db.Uuid
  sessionId                String               @unique @map("session_id") @db.Uuid
  workspaceId              String               @map("workspace_id") @db.Uuid
  evaluatorPromptVersionId String               @map("evaluator_prompt_version_id") @db.Uuid
  empathyScore             Int                  @map("empathy_score")
  empathySummary           String               @map("empathy_summary")
  clarityScore             Int                  @map("clarity_score")
  claritySummary           String               @map("clarity_summary")
  problemSolvingScore      Int                  @map("problem_solving_score")
  problemSolvingSummary    String               @map("problem_solving_summary")
  professionalismScore     Int                  @map("professionalism_score")
  professionalismSummary   String               @map("professionalism_summary")
  overallSummary           String               @map("overall_summary")
  createdAt                DateTime             @default(now()) @map("created_at")
  session                  Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evaluatorPromptVersion   PromptVersion        @relation(fields: [evaluatorPromptVersionId], references: [id])
  evidence                 EvaluationEvidence[]

  // Rolling competency averages for the manager dashboard (Phase 3).
  @@index([workspaceId, createdAt])
  @@map("evaluation")
}

// A verbatim quote from the transcript backing one coaching claim. Every
// quote is validated server-side as a real substring of the cited message —
// hallucinated evidence never persists (docs/architecture.md §6c).
model EvaluationEvidence {
  id           BigInt       @id @default(autoincrement())
  evaluationId String       @map("evaluation_id") @db.Uuid
  // Denormalized for future indexing/aggregation ONLY — the RLS policy
  // resolves visibility through evaluation → session, never this column.
  workspaceId  String       @map("workspace_id") @db.Uuid
  competency   Competency
  kind         EvidenceKind
  messageId    BigInt       @map("message_id")
  quote        String
  rationale    String
  evaluation   Evaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([messageId])
  @@map("evaluation_evidence")
}

// Work queue for the evaluator (Postgres-as-queue, lease-claimed with
// FOR UPDATE SKIP LOCKED). Service-path only — no client grants at all.
model PendingEvaluation {
  sessionId     String   @id @map("session_id") @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  attempts      Int      @default(0)
  lastError     String?  @map("last_error")
  nextAttemptAt DateTime @default(now()) @map("next_attempt_at")
  createdAt     DateTime @default(now()) @map("created_at")
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([nextAttemptAt])
  @@map("pending_evaluation")
}
